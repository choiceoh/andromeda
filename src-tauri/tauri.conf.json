{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Andromeda",
  "version": "0.0.11",
  "identifier": "ai.deneb.andromeda",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Andromeda",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/choiceoh/andromeda/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0MkMyRjQ2QUE5RjhCMEQKUldRTmk1K3FSaThzaEJLUS91VkZwZUxyMnlqelppbU42VmlsRFI1azN3cnl5T3Bya3NERThBb3QK"
    }
  }
}
