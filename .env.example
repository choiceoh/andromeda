# Optional gateway auto-connect for web/dev builds. A value entered in the sidebar
# (saved to localStorage) always takes precedence over these. Copy to `.env.local`.
#
# VITE_GATEWAY_URL=http://100.x.x.x:18789      # Tailscale/LAN URL of the Deneb gateway
# VITE_GATEWAY_TOKEN=<hex64>                   # client token — prefer the desktop
#   keychain / ~/.deneb/client_token over committing a token here.
#
# Logging: VITE_LOG_LEVEL=debug|info|warn|error
